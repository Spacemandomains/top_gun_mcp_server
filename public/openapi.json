{
  "openapi": "3.1.0",
  "info": {
    "title": "Top GUN GEO-Lens API",
    "description": "Professional auditing for Generative Engine Optimization (GEO). Measures brand visibility and citations in LLM search results.",
    "version": "1.0.0",
    "x-logo": {
      "url": "https://top-gun-mcp-server.vercel.app/top-gun-favicon.png",
      "altText": "Top GUN GEO-Lens API"
    },
    "guidance": "This API audits brand and topic visibility across Large Language Models. Call GET /api/v1/audit?query=<brand> to receive a visibility score (0-100), top citation URLs, LLM index status, and actionable GEO recommendations. Payment of $1.50 USD is required per request. If no payment credential is provided, the server returns HTTP 402 with payment instructions. Complete payment, then retry with the required payment credential."
  },
  "servers": [
    {
      "url": "https://top-gun-mcp-server.vercel.app",
      "description": "Production server managed by Wilfred L. Lee Jr."
    }
  ],
  "paths": {
    "/api/v1/audit": {
      "get": {
        "summary": "Perform a GEO visibility audit",
        "operationId": "getGeoAudit",
        "x-payment-info": {
          "pricingMode": "fixed",
          "price": "1.50",
          "currency": "USD",
          "protocols": ["mpp-tempo-1"]
        },
        "x-payment": {
          "mode": "fixed",
          "amount": "1.50",
          "currency": "USD",
          "protocols": ["mpp-tempo-1"]
        },
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "The brand or topic to audit for LLM visibility",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Audit",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "visibility_score": {
                      "type": "string"
                    },
                    "top_citations": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "llm_index_status": {
                      "type": "string"
                    },
                    "provider": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "402": {
            "description": "Payment Required - $1.50 USD per request"
          }
        }
      }
    }
  }
}
